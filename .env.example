# Copy to .env for local development. .env is gitignored — never commit secrets.

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev (docker-compose.yml):
DATABASE_URL=postgres://tennis:tennis@localhost:5432/tennis
#
# Production (Neon — see docs/DEPLOYMENT.md):
#   - The WORKER and migrations use the DIRECT url (no "-pooler" in the host).
#   - The WEB APP (Vercel env var) uses the POOLED url (host contains "-pooler").
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.us-west-2.aws.neon.tech/neondb?sslmode=require

# ── Worker (crawler) ─────────────────────────────────────────────────────────
# Bot account name; resolves creds + session under ~/.tennis-platform/.
TENNIS_ACCOUNT=norcal
# Contact email sent in the crawler's User-Agent (required by incremental.sh).
TENNIS_CONTACT_EMAIL=you@example.com
